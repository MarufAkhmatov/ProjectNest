# Build the Vite frontend, then serve it with nginx (which also reverse-proxies
# /api to the backend container). The app calls same-origin "/api" so it works
# over localhost, the LAN IP, or a public tunnel with no rebuild.
FROM node:20-alpine AS build
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install
COPY . .
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
